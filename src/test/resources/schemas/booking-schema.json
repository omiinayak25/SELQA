{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Restful-Booker Booking",
  "description": "JSON Schema for GET /booking/{id} response from restful-booker.herokuapp.com",
  "type": "object",
  "required": ["firstname", "lastname", "totalprice", "depositpaid", "bookingdates"],
  "properties": {
    "firstname": {
      "type": "string",
      "minLength": 1,
      "description": "Guest first name"
    },
    "lastname": {
      "type": "string",
      "minLength": 1,
      "description": "Guest last name"
    },
    "totalprice": {
      "type": "integer",
      "minimum": 0,
      "description": "Total price in implicit currency"
    },
    "depositpaid": {
      "type": "boolean",
      "description": "Whether the deposit has been paid"
    },
    "bookingdates": {
      "type": "object",
      "required": ["checkin", "checkout"],
      "properties": {
        "checkin": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO-8601 check-in date (YYYY-MM-DD)"
        },
        "checkout": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO-8601 check-out date (YYYY-MM-DD)"
        }
      },
      "additionalProperties": false
    },
    "additionalneeds": {
      "type": "string",
      "description": "Optional additional guest requests"
    }
  },
  "additionalProperties": false
}
