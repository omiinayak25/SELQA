{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JSONPlaceholder Todo",
  "description": "JSON Schema for a single todo object from GET /todos/{id}",
  "type": "object",
  "required": ["id", "userId", "title", "completed"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Server-assigned todo identifier",
      "minimum": 1
    },
    "userId": {
      "type": "integer",
      "description": "Foreign key to owning user",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short task description"
    },
    "completed": {
      "type": "boolean",
      "description": "true if the task is done"
    }
  },
  "additionalProperties": false
}
