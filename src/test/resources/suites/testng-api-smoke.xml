<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  API smoke — the CI-reliable subset. Scoped to public endpoints that are
  stable and key-free (JSONPlaceholder, GraphQL Countries, DummyJSON), so this
  suite gives a dependable green/red signal.

  Deliberately EXCLUDES:
    - httpbin.org   (frequently returns 503 under load — environmental)
    - reqres.in     (moved to account-gated API keys; 401 without a valid key)
  Those live in the full testng-api.xml and are covered when their services are
  healthy / credentialed. See docs/EXECUTION_GUIDE.md "External endpoint notes".
-->
<suite name="OmiinQA-API-Smoke" parallel="methods" thread-count="4" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.RetryTransformer"/>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="API-Smoke-Stable">
        <packages>
            <package name="com.omiinqa.api.jsonplaceholder.*"/>
            <package name="com.omiinqa.api.graphql.*"/>
        </packages>
        <classes>
            <class name="com.omiinqa.api.DummyJsonApiTest"/>
        </classes>
    </test>
</suite>
