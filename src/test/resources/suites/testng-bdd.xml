<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- BDD suite: runs the Cucumber runner. Requires a browser/Grid. -->
<suite name="OmiinQA-BDD" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="Cucumber-BDD">
        <classes>
            <class name="com.omiinqa.bdd.runners.CucumberTestRunner"/>
        </classes>
    </test>
</suite>
