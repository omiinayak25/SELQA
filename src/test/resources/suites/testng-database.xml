<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Database suite. Requires a live PostgreSQL/MySQL with the expected schema
  (see docs). Excluded from default runs; run explicitly when a DB is available.
-->
<suite name="OmiinQA-Database" parallel="classes" thread-count="2" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="Database-Tests">
        <groups>
            <run><include name="database"/></run>
        </groups>
        <packages>
            <package name="com.omiinqa.database"/>
        </packages>
    </test>
</suite>
