<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Embedded database integration — runs the REAL database stack against an
  in-memory H2 (PostgreSQL-compat) with zero external infrastructure, so CI gets
  a dependable DB gate. Sequential: all methods share one in-memory database and
  assert on seeded baselines.
-->
<suite name="OmiinQA-DB-Embedded" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="Embedded-H2-Integration">
        <groups>
            <run><include name="db-embedded"/></run>
        </groups>
        <classes>
            <class name="com.omiinqa.database.EmbeddedDbIntegrationTest"/>
        </classes>
    </test>
</suite>
