<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- End-to-end journeys (UI + API + DB orchestrated). Requires browser + network. -->
<suite name="OmiinQA-E2E" parallel="methods" thread-count="2" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.RetryTransformer"/>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="E2E">
        <packages>
            <package name="com.omiinqa.e2e"/>
        </packages>
    </test>
</suite>
