<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Smoke suite: fast, fully offline sanity of the framework core.
  Scoped to the unit package so it runs anywhere (CI, laptop, container) with
  no browser, database or network. This is the build's green-gate suite.
-->
<suite name="OmiinQA-Smoke" parallel="methods" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="com.omiinqa.listeners.RetryTransformer"/>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>

    <test name="Framework-Core-Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.omiinqa.unit"/>
        </packages>
    </test>
</suite>
