<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Specialized quality layers: accessibility (axe), performance smoke (navigation
  timing), visual regression (baseline diff), security (injection/session) and
  responsive (viewport matrix). Requires a browser / Grid. Each lens asserts a
  different property of the same pages.
-->
<suite name="OmiinQA-Specialized" parallel="methods" thread-count="3" verbose="1">
    <listeners>
        <listener class-name="com.omiinqa.listeners.RetryTransformer"/>
        <listener class-name="com.omiinqa.listeners.TestListener"/>
        <listener class-name="com.omiinqa.reports.ExtentReportListener"/>
    </listeners>
    <test name="Specialized-Layers">
        <packages>
            <package name="com.omiinqa.accessibility"/>
            <package name="com.omiinqa.performance"/>
            <package name="com.omiinqa.visual"/>
            <package name="com.omiinqa.security"/>
            <package name="com.omiinqa.responsive"/>
        </packages>
    </test>
</suite>
